{
  "name": "edenred-pokeapi-cypress",
  "version": "1.0.0",
  "description": "API automation tests for PokeAPI using Cypress",
  "main": "index.js",
  "scripts": {
    "test": "npm run cy:run",
    "cy:open": "node scripts/run-cypress.js open",
    "cy:run": "node scripts/run-cypress.js run",
    "test:api": "node scripts/run-cypress.js run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:berry": "node scripts/run-cypress.js run --spec \"cypress/e2e/api/berry/**/*.cy.js\"",
    "test:smoke": "node scripts/run-cypress.js run --env grepTags=@smoke",
    "test:regression": "node scripts/run-cypress.js run --env grepTags=@regression",
    "test:tag:smoke": "node scripts/run-cypress.js run --env grepTags=@smoke",
    "test:tag:regression": "node scripts/run-cypress.js run --env grepTags=@regression",
    "test:ci:pr": "node scripts/run-cypress.js run --env grepTags=@smoke --reporter junit --reporter-options \"mochaFile=results/junit/pr-[hash].xml,toConsole=true\"",
    "test:ci:nightly": "node scripts/run-cypress.js run --env grepTags=@regression --reporter junit --reporter-options \"mochaFile=results/junit/nightly-[hash].xml,toConsole=true\""
  },
  "keywords": [
    "cypress",
    "pokeapi",
    "api-testing",
    "qa-automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@bahmutov/cy-grep": "^2.1.0",
    "cypress": "^13.17.0"
  }
}
